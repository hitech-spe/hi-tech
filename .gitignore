# ==========================================
# Dipendenze Node.js
# ==========================================
/node_modules
npm-debug.log
yarn-error.log
yarn-debug.log
package-lock.json

# (Nota: se usi npm mantieni package-lock.json nel repository, 
# se invece causa conflitti rimuovi il commento dalla riga sopra per ignorarlo)

# ==========================================
# Output di compilazione e cache di Angular
# ==========================================
/dist
/tmp
/out-tsc
/bazel-out
/.angular

